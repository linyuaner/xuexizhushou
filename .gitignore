# ─── 依赖 ───────────────────────────────────────────────
node_modules/
server/node_modules/

# ─── 构建产物 ────────────────────────────────────────────
dist/
server/public/

# ─── 环境变量（敏感信息不入库）────────────────────────────
.env
.env.local
.env.*.local
server/.env

# ─── 数据库 & 上传文件 ────────────────────────────────────
server/data/
server/uploads/

# ─── 编辑器 / 系统文件 ───────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── 日志 ───────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── 测试覆盖率 ──────────────────────────────────────────
coverage/
.nyc_output/

# ─── 临时文件 ────────────────────────────────────────────
*.tmp
*.temp
.cache/

# ─── 工作区辅助文件 ──────────────────────────────────────
.workbuddy/
.gitignore
